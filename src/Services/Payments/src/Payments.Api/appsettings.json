{
  "Logging": {
    "LogLevel": {
      "Default": "Information"
    }
  },
  "Database": {
    // Supported values: "PostgreSQL" (default) | "SqlServer"
    // Override via env var:  Database__Provider=SqlServer
    // When running via Aspire, the AppHost propagates DatabaseProvider automatically.
    "Provider": "PostgreSQL"
  },
  "ConnectionStrings": {
    // PostgreSQL — local Docker / Azure Database for PostgreSQL Flexible Server:
    //   "PaymentsDb": "Host=<server>.postgres.database.azure.com;Database=payments_db;Username=<user>;Password=<pwd>;SslMode=Require;"
    // SQL Server — local Docker / Azure SQL Database:
    //   "PaymentsDb": "Server=<server>.database.windows.net;Database=payments_db;Authentication=Active Directory Managed Identity;"
    "PaymentsDb": "Host=localhost;Database=payments_db;Username=postgres;Password=postgres",
    "RabbitMq": "rabbitmq://guest:guest@localhost"
  },
  "PaymentSettings": {
    "SupportedPaymentMethods": [ "CreditCard", "PayPal", "BankTransfer" ],
    "Currency": "USD",
    "MaxPaymentAmount": 10000,
    "PaymentGateway": {
      "Provider": "Stripe",
      "Stripe": {
        "ApiKey": "your-stripe-api-key"
      }
    },
    "RetryPolicy": {
      "MaxRetryAttempts": 3,
      "DelaySeconds": 2
    },
    "FraudDetection": {
      "Enabled": true,
      "Provider": "MockFraudDetectionService",
      "MockFraudDetectionService": {
        "FraudScoreThreshold": 0.7
      }
    },
    "Notification": {
      "Enabled": true,
      "Provider": "MockNotificationService",
      "MockNotificationService": {
        "SuccessMessageTemplate": "Your payment of {Amount} {Currency} was successful!",
        "FailureMessageTemplate": "Your payment of {Amount} {Currency} failed. Please try again."
      }
    },
    "Logging": {
      "LogPaymentDetails": true,
      "LogSensitiveData": false
    }
  }
}
